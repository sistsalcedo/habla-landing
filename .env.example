# Supabase (obligatorio para Auth)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Formspree (para Newsletter y Contacto)
# Crear formularios en formspree.io y pegar los IDs (ej. xyzabc de https://formspree.io/f/xyzabc)
VITE_FORMSPREE_NEWSLETTER_ID=
VITE_FORMSPREE_CONTACT_ID=

# Demo (URL del asistente de voz en vivo)
VITE_DEMO_URL=https://demo.habla.cloud

# Mercado Pago (checkout — solo servidor, añadir en Vercel Environment Variables)
# Obtener en https://www.mercadopago.com.pe/developers → Tu app → Credenciales
# Prueba: Access Token de prueba | Producción: Access Token productivo
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx

# Supabase (solo servidor — webhook de Mercado Pago)
# URL: mismo que VITE_SUPABASE_URL | Service Role Key: Dashboard > Settings > API
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cron: procesar eliminaciones programadas (borrado diferido 30 días)
# El endpoint /api/cron-procesar-bajas requiere este secret (header Authorization: Bearer o ?secret=)
# Configurar cron externo (cron-job.org, EasyCron) o Vercel Cron (Pro) — ver docs_reference/CRON-BAJA-CUENTA.md
CRON_SECRET=genera-un-secreto-aleatorio-largo

# Opcional: URL base del sitio (Vercel usa VERCEL_URL automáticamente)
# SITE_URL=https://tu-dominio.vercel.app

# Google Analytics 4 (opcional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
